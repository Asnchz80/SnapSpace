{
  "rules": {
    // Authenticated users can only read/write their own data.
    // All other paths — including unauthenticated access — are denied.
    "users": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",

        // Redesign history: each entry must have createdAt + style fields.
        "redesigns": {
          "$redesignId": {
            ".validate": "newData.hasChildren(['createdAt', 'style'])"
          }
        }
      }
    },

    // AI improvement data — separate branch for training/feedback collection.
    // Each user can only access their own subtree.
    "aiImprovement": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",

        // Each scan session
        "$scanId": {
          // meta: must have createdAt
          "meta": {
            ".validate": "newData.hasChild('createdAt')"
          },
          // styles: each style entry must have imageUrl + generatedAt
          "styles": {
            "$styleId": {
              ".validate": "newData.hasChildren(['imageUrl', 'generatedAt'])"
            }
          },
          // areaRedos: each redo must have style + instruction + timestamp
          "areaRedos": {
            "$entry": {
              ".validate": "newData.hasChildren(['style', 'instruction', 'timestamp'])"
            }
          },
          // chatThread: each message must have role + content + timestamp
          "chatThread": {
            "$entry": {
              ".validate": "newData.hasChildren(['role', 'content', 'timestamp'])"
            }
          }
        }
      }
    }
  }
}
