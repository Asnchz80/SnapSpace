# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# In CI/CD (GitHub Actions), all VITE_* values are stored as GitHub Secrets.

# ── Gemini AI ────────────────────────────────────────────────────────────────
# Get a free key at: https://aistudio.google.com/apikey
# IMPORTANT: Restrict this key to your production domain in Google AI Studio
# (e.g. snapspace-4d243.web.app) to prevent unauthorized use.
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ── Firebase project config ──────────────────────────────────────────────────
# Find these in Firebase Console → Project Settings → Your apps → SDK config.
# These are public identifiers by Firebase design, but kept out of source code
# so the repo is environment-agnostic and no project IDs leak via git history.
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Local emulator (optional) ────────────────────────────────────────────────
# Set to true only when running `firebase emulators:start` locally.
VITE_USE_EMULATOR=false

# ── GitHub Secrets required (repo Settings → Secrets → Actions) ─────────────
# VITE_GEMINI_API_KEY
# VITE_FIREBASE_API_KEY
# VITE_FIREBASE_AUTH_DOMAIN
# VITE_FIREBASE_DATABASE_URL
# VITE_FIREBASE_PROJECT_ID
# VITE_FIREBASE_STORAGE_BUCKET
# VITE_FIREBASE_MESSAGING_SENDER_ID
# VITE_FIREBASE_APP_ID
# VITE_FIREBASE_MEASUREMENT_ID
# FIREBASE_SERVICE_ACCOUNT_SNAPSPACE_4D243  (service account JSON for deploy)
