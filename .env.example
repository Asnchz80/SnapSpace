# Copy this file to .env.local and fill in your values.
# NEVER commit .env or .env.local to version control.

# Gemini API key — used directly by the frontend AND by Firebase Cloud Functions.
# Get a free key at: https://aistudio.google.com/apikey
# Gemini 2.0 Flash free tier: 1,500 requests/day, 15 RPM — no billing required.
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# For Cloud Functions (production), store it as a Firebase Secret instead:
#   firebase functions:secrets:set GEMINI_API_KEY
# Then paste your key when prompted.

# Optional: connect to local emulator for development
VITE_USE_EMULATOR=false
